generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("CUSTOMER") // CUSTOMER, VENDOR, ADMIN
  phone     String?
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendor         Vendor?
  bookings       Booking[]
  reviews        Review[]
  aiRecommendations AIRecommendation[]
  eventPlans       EventPlan[]
}

model Vendor {
  id           String @id @default(cuid())
  userId       String @unique
  businessName String
  address      String?
  phone        String?
  description  String?
  isVerified   Boolean @default(false)
  isSuspended  Boolean @default(false)
  rating       Float   @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  products Product[]
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  icon      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
}

model Product {
  id             String   @id @default(cuid())
  vendorId       String
  categoryId     String
  title          String
  slug           String
  description    String
  features       String   // JSON array string
  buyPrice       Float
  rentPricePerDay Float
  deposit        Float    @default(0)
  stock          Int      @default(1)
  status         String   @default("AVAILABLE") // AVAILABLE, UNAVAILABLE
  imageUrl       String?
  images         String?  // JSON array of image paths, e.g. ["/uploads/products/abc.jpg"]
  condition      String   @default("NEW") // NEW, LIKE_NEW, GOOD, FAIR
  listingTypes   String   @default("RENT,BOOK")
  location       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  vendor     Vendor       @relation(fields: [vendorId], references: [id])
  category   Category     @relation(fields: [categoryId], references: [id])
  bookings   Booking[]
  reviews    Review[]
}

model Booking {
  id            String   @id @default(cuid())
  userId        String
  productId     String
  bookingType   String   // RENT, BUY, BOOK
  startDate     DateTime?
  endDate       DateTime?
  quantity      Int      @default(1)
  totalPrice    Float
  depositAmount Float    @default(0)
  status        String   @default("PENDING") // PENDING, APPROVED, CONFIRMED, DELIVERED, RETURNED, COMPLETED, CANCELLED, REJECTED
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user        User       @relation(fields: [userId], references: [id])
  product     Product    @relation(fields: [productId], references: [id])
  payment     Payment?
  return_      Return?
  review      Review?
  aiRecommendations AIRecommendation[]
  packageBookings  PackageBooking[]
}

model Payment {
  id            String   @id @default(cuid())
  bookingId     String   @unique
  paymentStatus String   @default("PENDING") // PENDING, COMPLETED, FAILED, REFUNDED
  paymentMethod String   @default("ONLINE") // ONLINE, CASH, UPI, CARD
  amount        Float
  paidAt        DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id])
}

model Return {
  id           String   @id @default(cuid())
  bookingId    String   @unique
  returnDate   DateTime?
  returnStatus String   @default("PENDING") // PENDING, INSPECTING, COMPLETED, DAMAGE_REPORTED
  damageNotes  String?
  fineAmount   Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  productId String
  bookingId String?  @unique
  rating    Int      // 1-5
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])
  booking Booking? @relation(fields: [bookingId], references: [id])
}

model AIRecommendation {
  id             String   @id @default(cuid())
  userId         String?
  bookingId      String?
  prompt         String
  recommendation String
  explanation    String
  savings        Float?
  alternatives   String?  // JSON array string
  createdAt      DateTime @default(now())

  user     User?    @relation(fields: [userId], references: [id])
  booking  Booking? @relation(fields: [bookingId], references: [id])
}

model EventPlan {
  id              String   @id @default(cuid())
  userId          String
  eventType       String   // Wedding, Concert, Corporate, Birthday, Conference, etc.
  guests          Int
  venueType       String   // Indoor, Outdoor, Both
  budget          Float
  city            String?
  duration        Int      @default(1) // days
  eventDate       DateTime?
  requirements    String?  // additional requirements text
  preference      String   @default("RENT") // RENT, BUY, BOTH
  quality         String   @default("STANDARD") // BASIC, STANDARD, PREMIUM
  aiPrompt        String?  // the full prompt sent to AI
  aiResponse      String?  // raw AI response
  packages        String   // JSON: the 3 package options (economy, standard, premium)
  selectedTier    String?  // ECONOMY, STANDARD, PREMIUM
  status          String   @default("DRAFT") // DRAFT, BOOKED, CANCELLED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User             @relation(fields: [userId], references: [id])
  packageBookings PackageBooking[]
}

model PackageBooking {
  id          String     @id @default(cuid())
  eventPlanId String
  tier        String     // ECONOMY, STANDARD, PREMIUM
  totalCost   Float
  totalDeposit Float     @default(0)
  savings     Float      @default(0)
  status      String     @default("PENDING") // PENDING, CONFIRMED, DELIVERED, COMPLETED, CANCELLED
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  eventPlan   EventPlan      @relation(fields: [eventPlanId], references: [id])
  items       PackageItem[]
  bookings    Booking[]
}

model PackageItem {
  id               String  @id @default(cuid())
  packageBookingId String
  productId        String?
  categoryId       String?
  productName      String  // fallback name if no product matched
  quantity         Int
  rentPricePerDay  Float   @default(0)
  buyPrice         Float   @default(0)
  duration         Int     @default(1) // days
  subtotal         Float
  vendorId         String?
  vendorName       String?
  priority         String  @default("MEDIUM") // HIGH, MEDIUM, LOW
  reason           String?
  createdAt        DateTime @default(now())

  packageBooking PackageBooking @relation(fields: [packageBookingId], references: [id])
}